{
  "name": "clisbot",
  "version": "0.1.43",
  "private": false,
  "description": "Chat surfaces for durable AI coding agents running in tmux",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longbkit/clisbot.git"
  },
  "bugs": {
    "url": "https://github.com/longbkit/clisbot/issues"
  },
  "homepage": "https://github.com/longbkit/clisbot#readme",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "bin": {
    "clisbot": "bin/clisbot",
    "clis": "bin/clis"
  },
  "files": [
    "bin",
    "dist",
    "config",
    "templates",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && bun build ./src/main.ts --target=node --outfile ./dist/main.js",
    "dev": "bun --watch run src/main.ts serve-foreground",
    "start": "bash ./scripts/run-dev-cli.sh start",
    "restart": "bash ./scripts/run-dev-cli.sh restart",
    "stop": "bash ./scripts/run-dev-cli.sh stop",
    "status": "bash ./scripts/run-dev-cli.sh status",
    "logs": "bash ./scripts/run-dev-cli.sh logs",
    "init": "bash ./scripts/run-dev-cli.sh init",
    "print-config-path": "bun run src/main.ts print-config-path",
    "pairing": "bash ./scripts/run-dev-cli.sh pairing",
    "typecheck": "bunx tsc --noEmit",
    "test": "env -u SLACK_APP_TOKEN -u SLACK_BOT_TOKEN -u TELEGRAM_BOT_TOKEN -u TELEGRAM_CONTROL_BOT_TOKEN -u TELEGRAM_DEV_BOT_TOKEN bun test --preload ./test/preload-env.ts",
    "prepack": "bun run build",
    "check": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.24.2"
  },
  "keywords": [
    "ai",
    "slack",
    "telegram",
    "tmux",
    "codex",
    "claude"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "bun-types": "^1.3.8",
    "typescript": "^5.8.3"
  }
}
